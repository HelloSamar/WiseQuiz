# DO NOT commit actual credentials to the repository!
# This file is listed in .gitignore and should never be pushed to Git.

# Copy this template to .env and fill in your actual credentials:
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# SECRET_KEY=your_secret_key_here  (will be auto-generated if not provided)
# PORT=5000  (optional, defaults to 5000)
